pipeline {
    agent any
    environment {
        DOCKERHUB_USER = 'nattasitfluk'
        IMAGE_NAME     = "${DOCKERHUB_USER}/todo-backend"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        // ID ต้องตรงกับที่ตั้งใน Jenkins Credentials
        DOCKER_CREDS   = 'docker-hub-credentials' 
    }

    stages {
        stage('1. Checkout') {
            steps {
                checkout scm
            }
        }

        // หมายเหตุ: ตัด stage Test ออกก่อนหากในเครื่องไม่มี Go 
        // หรือจะรัน Test ภายใต้ Docker Container ก็ได้ครับ

        stage('2. Build & Push to Docker Hub') {
            steps {
                script {
                    // ใช้ docker.withRegistry เพื่อจัดการเรื่อง Login อัตโนมัติ
                    docker.withRegistry('', "${DOCKER_CREDS}") {
                        // สั่ง build โดยชี้ไปที่โฟลเดอร์ backend
                        def backendImage = docker.build("${IMAGE_NAME}:${IMAGE_TAG}", "./backend")
                        
                        // Push ทั้งแบบระบุเลข Build และแบบ latest
                        backendImage.push()
                        backendImage.push("latest")
                    }
                }
            }
        }
    }

    post {
        success {
            echo '✅ Backend Build & Push สำเร็จ!'
        }
        failure {
            echo '❌ Backend Build ล้มเหลว'
        }
        always {
            cleanWs() // ล้างพื้นที่หลังจบงาน
        }
    }
}