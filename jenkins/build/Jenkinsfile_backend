pipeline {
    agent any
    environment {
        DOCKERHUB_USER = 'nattasitfluk'
        IMAGE_NAME     = "${DOCKERHUB_USER}/todo-backend"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        DOCKER_CREDS   = 'docker-hub-credentials'
    }

    stages {
        // Stage 1: ดึงโค้ดล่าสุดจาก GitHub
        stage('1. Checkout') {
            steps {
                checkout scm
            }
        }

        // Stage 2: ติดตั้ง Dependencies หรือ Compile (ตามรูปอาจารย์)
        stage('2. Build') {
            steps {
                echo '📦 Installing dependencies and compiling...'
                // สำหรับ Go backend:
                // sh 'cd backend && go mod download'
            }
        }

        // Stage 3: รัน Unit Test (ต้องมีไฟล์ _test.go ในโปรเจกต์)
        stage('3. Test') {
            steps {
                echo '🧪 Running Unit Tests...'
                // sh 'cd backend && go test ./...'
            }
        }

        // Stage 4: สร้าง Docker Image
        stage('4. Docker Build') {
            steps {
                script {
                    echo '🏗️ Building Docker Image...'
                    // สั่ง build โดยชี้ไปที่โฟลเดอร์ backend
                    backendImage = docker.build("${IMAGE_NAME}:${IMAGE_TAG}", "./backend")
                }
            }
        }

        // Stage 5: ส่ง Image ขึ้น Docker Hub
        stage('5. Push Hub') {
            steps {
                script {
                    echo '🚀 Pushing Image to Docker Hub...'
                    docker.withRegistry('', "${DOCKER_CREDS}") {
                        backendImage.push()
                        backendImage.push("latest")
                    }
                }
            }
        }

        // Stage 6: สั่ง Deploy ด้วย Terraform ตาม Key Setup Tasks
        stage('6. Deploy') {
            steps {
                echo '🛠️ Deploying to Kubernetes via Terraform...'
                dir('terraform') {
                    // ปลดคอมเมนต์ด้านล่างเมื่อเตรียมไฟล์ .tf ในโฟลเดอร์ terraform เสร็จแล้ว
                    // sh 'terraform init'
                    // sh 'terraform apply -auto-approve'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline ทั้ง 6 Stages สำเร็จเรียบร้อย!'
        }
        failure {
            echo '❌ Pipeline ล้มเหลว กรุณาเช็ค Console Output'
        }
        always {
            echo '🧹 Cleaning up workspace...'
            cleanWs()
            // ลบ image ที่ build ค้างไว้ในเครื่อง Jenkins เพื่อประหยัดพื้นที่
            sh 'docker image prune -f || true'
        }
    }
}