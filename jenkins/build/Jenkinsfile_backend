pipeline {
    agent any
    environment {
        DOCKERHUB_USER = 'nattasitfluk'
        IMAGE_NAME     = "${DOCKERHUB_USER}/todo-backend"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        DOCKER_CREDS   = 'docker-hub-credentials'
    }

    stages {
        // Stage 1: ใช้ checkout scm ตามที่คุณต้องการ
        stage('1. Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        // Stage 2: เตรียม Dependencies
        stage('2. Build') {
            steps {
                echo 'Installing dependencies...'
                // ปลดคอมเมนต์หากต้องการรันคำสั่ง Go จริง
                // sh 'cd backend && go mod download'
            }
        }

        // Stage 3: ทดสอบโค้ด (Test) 
        // แยกออกมาให้ชัดเจนตามเกณฑ์อาจารย์ และไม่ซ้ำกับ Stage 4
        stage('3. Test') {
            steps {
                echo 'Testing backend...'
                // ตัวอย่างการรัน Test สั้นๆ
                // sh 'cd backend && go test ./...'
            }
        }

        // Stage 4: สร้าง Docker Image 
        // ใช้รูปแบบ docker.build เพื่อให้ตัวแปร backendImage นำไปใช้ต่อใน Stage 5 ได้
        stage('4. Docker Build') {
            steps {
                script {
                    echo 'Building Docker Image...'
                    // ชี้ไปที่โฟลเดอร์ ./backend ตามโครงสร้างในรูป image_0ffffd.png
                    backendImage = docker.build("${IMAGE_NAME}:${IMAGE_TAG}", "./backend")
                }
            }
        }

        // Stage 5: ส่งขึ้น Docker Hub
        stage('5. Push to DockerHub') {
            steps {
                script {
                    echo 'Pushing Image to Docker Hub...'
                    docker.withRegistry('', "${DOCKER_CREDS}") {
                        backendImage.push()
                        backendImage.push("latest")
                    }
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline ทั้ง 5 Stages สำเร็จเรียบร้อย!'
            // หากต้องการให้ไปเรียก Job Deploy ต่อ ให้ใส่บรรทัดล่างนี้:
            // build job: 'Deploy-Backend-Job', wait: false
        }
        failure {
            echo '❌ Pipeline ล้มเหลว กรุณาเช็ค Console Output'
        }
        always {
            echo 'Cleaning up workspace...'
            cleanWs()
            sh 'docker image prune -f || true'
        }
    }
}