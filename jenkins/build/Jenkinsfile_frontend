pipeline {
    agent any

    options {
        skipDefaultCheckout()
    }

    environment {
        DOCKER_USER = "nattasitfluk"
        IMAGE_NAME  = "${DOCKER_USER}/todo-frontend"
        version     = "${BUILD_NUMBER}" 
    }

    stages {
        stage('1. Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('2. Build & Test') {
            steps {
                echo "Preparing frontend dependencies for version: ${version}"
            }
        }

        stage('3. Docker Build') {
            steps {
                script {
                    echo "Building Docker Image..."
                    sh "cd frontend && docker build . -t ${IMAGE_NAME}:${version}"
                    sh "docker tag ${IMAGE_NAME}:${version} ${IMAGE_NAME}:latest"
                }
            }
        }

        stage('4. Test Docker Image') {
            steps {
                script {
                    echo "Testing Frontend Container..."
                    sh "docker run --rm ${IMAGE_NAME}:${version} echo 'Frontend Service Started Successfully!'"
                }
            }
        }

        stage('5. Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'D_USER',
                    passwordVariable: 'D_PASS'
                )]) {
                    sh """
                        echo \$D_PASS | docker login -u \$D_USER --password-stdin
                        docker push ${IMAGE_NAME}:${version}
                        docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('6. Trigger Deploy') {
            steps {
                build job: 'deploy-frontend', 
                parameters: [string(name: 'version', value: "${env.BUILD_NUMBER}")],
                wait: false
            }
        } 
    } // <--- ต้องมีปีกกาปิด stages ตรงนี้

    post {
        always {
            echo "Post-build cleanup..."
            sh "docker rmi ${IMAGE_NAME}:${version} ${IMAGE_NAME}:latest || true"
            sh "docker logout || true"
            cleanWs()
        }
        success {
            echo "✅ Frontend Build & Push Completed!"
        }
        failure {
            echo "❌ Build Failed! Please check the console output."
        }
    }
}