pipeline {
    agent { label "wsl" } // ใช้ Label ตามสภาพแวดล้อมที่คุณใช้งาน

    environment {
        DOCKER_USER = "nattasitfluk"
        IMAGE_NAME  = "${DOCKER_USER}/todo-frontend"
        // ใช้ BUILD_NUMBER เพื่อระบุเวอร์ชันในแต่ละรอบการ Build
        version     = "${BUILD_NUMBER}" 
    }

    stages {
        // Stage 1: ใช้ checkout scm ตามที่คุณระบุ เพื่อความง่ายในการจัดการผ่าน UI
        stage('1. Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        // Stage 2: เตรียม Environment และตรวจสอบโค้ดเบื้องต้น
        stage('2. Build & Test') {
            steps {
                echo "Preparing frontend dependencies for version: ${version}"
                // สามารถปลดคอมเมนต์เพื่อรันคำสั่งจริง เช่น npm install หรือ npm run build
                // sh "cd frontend && npm install && npm run build"
            }
        }

        // Stage 3: สร้าง Docker Image จากโฟลเดอร์ frontend
        stage('3. Docker Build') {
            steps {
                script {
                    echo "Building Docker Image..."
                    // ระบุ Path ไปยังโฟลเดอร์ frontend ตามโครงสร้างโปรเจกต์ของคุณ
                    sh "cd frontend && docker build . -t ${IMAGE_NAME}:${version}"
                    sh "docker tag ${IMAGE_NAME}:${version} ${IMAGE_NAME}:latest"
                }
            }
        }

        // Stage 4: ทดสอบรัน Container เพื่อเช็คความเรียบร้อย (ตามแนวทางตัวอย่างที่คุณส่งมา)
        stage('4. Test Docker Image') {
            steps {
                script {
                    echo "Testing Frontend Container..."
                    // ทดสอบรันเพื่อเช็คว่า Container สามารถ Start ได้ปกติ
                    sh "docker run --rm ${IMAGE_NAME}:${version} echo 'Frontend Service Started Successfully!'"
                }
            }
        }

        // Stage 5: ส่ง Image ขึ้น Docker Hub โดยใช้ Credentials ที่ตั้งไว้
        stage('5. Push to Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub', 
                                     usernameVariable: 'DUSER', 
                                     passwordVariable: 'DPASS')]) {
                        echo "Logging in to Docker Hub..."
                        sh "echo $DPASS | docker login -u $DUSER --password-stdin"
                        
                        echo "Pushing Image version: ${version}"
                        sh "docker push ${IMAGE_NAME}:${version}"
                        sh "docker push ${IMAGE_NAME}:latest"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Post-build cleanup..."
            // ลบ Image ในเครื่องเพื่อไม่ให้พื้นที่เต็มตามแนวทางที่คุณต้องการ
            sh "docker rmi ${IMAGE_NAME}:${version} ${IMAGE_NAME}:latest || true"
            sh "docker logout"
            cleanWs()
        }
        success {
            echo "✅ Frontend Build & Push Completed!"
        }
        failure {
            echo "❌ Build Failed! Please check the console output."
        }
    }
}