pipeline {
    agent any

    environment {
        DOCKERHUB_USER = 'nattasitfluk'
        NAMESPACE      = 'todo-app'
    }

    stages {
        stage('1. Checkout') {
            steps {
                checkout scm # ดึงไฟล์ k8s จาก GitHub ของคุณ
            }
        }

        stage('2. Deploy to Kubernetes') {
            steps {
                // สั่งให้ K8s อัปเดตตามไฟล์ YAML ที่เราเตรียมไว้
                sh """
                    kubectl apply -f k8s/backend/deployment.yaml -n ${NAMESPACE}
                    kubectl rollout restart deployment/todo-backend -n ${NAMESPACE}
                    kubectl rollout status deployment/todo-backend -n ${NAMESPACE}
                """
            }
        }
    }

    post {
        success {
            echo '✅ Backend Deploy สำเร็จและรันบน K8s แล้ว!'
        }
        failure {
            echo '❌ Deploy ล้มเหลว ตรวจสอบสิทธิ์ kubectl หรือไฟล์ YAML'
        }
    }
}