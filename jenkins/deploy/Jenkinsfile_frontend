pipeline {
    agent any

    tools {
        terraform 'terraform' 
    }
    
    parameters {
        string(name: 'version', defaultValue: 'latest', description: 'Image version to deploy')
    }

    stages {
        stage('1. Checkout Infrastructure') {
            steps {
                // ❌ ลบ cleanWs() ตรงนี้ออกไปแล้ว เพื่อไม่ให้มันลบสมุดจดก่อนเริ่มงาน
                checkout scm 
            }
        }

        stage('2. Deploy via Terraform') {
            steps {
                withCredentials([string(credentialsId: 'DB_PASSWORD', variable: 'TF_VAR_db_password')]) {
                    dir('terraform') {
                        sh 'terraform init'
                        sh "terraform apply -auto-approve -var='image_tag=${params.version}'"
                    }
                }
            }
        }

        stage('3. Verify Status') {
            steps {
                echo "Verifying Deployment Status..."
                sh "kubectl rollout status deployment/todo-frontend -n todo-app"
            }
        }
    }

    // ❌ ลบ block post { always { cleanWs() } } ข้างล่างสุดทิ้งไปเลย!
}