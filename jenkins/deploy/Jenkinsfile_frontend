pipeline {
    agent any

    tools {
        terraform 'terraform' 
    }
    
    parameters {
        string(name: 'version', defaultValue: 'latest', description: 'Image version to deploy')
    }

    stages {
        // Stage 1: เปลี่ยนกลับมาใช้ checkout scm ตามที่คุณต้องการ
        stage('1. Checkout Infrastructure') {
            steps {
                cleanWs()
                // Jenkins จะจัดการดึงโค้ดตามที่ตั้งค่าไว้ใน Pipeline Job (SCM) โดยอัตโนมัติ
                checkout scm 
            }
        }

        stage('2. Deploy via Terraform') {
            steps {
                script {
                    echo "Deploying Frontend version: ${params.version} to K8s Cluster..."
                    // ใช้ dir() เพื่อระบุตำแหน่งไฟล์ terraform ในโปรเจกต์
                    dir('terraform') {
                        sh "terraform init"
                        sh "terraform apply -auto-approve -var='image_version=${params.version}'"
                    }
                }
            }
        }

        stage('3. Verify Status') {
            steps {
                echo "Verifying Deployment Status..."
                // ตรวจสอบความเรียบร้อยของ Pod ใน namespace ที่กำหนด
                sh "kubectl rollout status deployment/todo-frontend -n todo-app"
            }
        }
    }

    post {
        always {
            echo "Cleaning workspace..."
            cleanWs()
        }
    }
}